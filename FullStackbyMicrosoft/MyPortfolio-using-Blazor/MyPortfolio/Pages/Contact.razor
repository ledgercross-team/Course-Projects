@page "/contact"
<PageTitle>Contact | Taharat Muhammad Jabir</PageTitle>

<div class="page-container">
    <h1>Get in Touch</h1>
    <p class="subtitle">Whether it's a research collaboration, an internship opportunity, or just a technical discussion, feel free to reach out.</p>

    <div class="contact-layout">
        <div class="contact-info">
            <h3>Contact Information</h3>
            <div class="info-item">
                <strong>Email:</strong>
                <a href="mailto:tmjabircr@gmail.com">tmjabircr@gmail.com</a>
            </div>
            <div class="info-item">
                <strong>Location:</strong>
                <span>Dhaka, Bangladesh</span>
            </div>
            <div class="info-item">
                <strong>Academic:</strong>
                <span>American International University-Bangladesh (AIUB)</span>
            </div>
            
            <h3 class="social-heading">Professional Profiles</h3>
            <div class="social-links">
                <a href="#" target="_blank" class="btn-secondary">GitHub</a>
                <a href="#" target="_blank" class="btn-secondary">LinkedIn</a>
            </div>
        </div>

        <div class="contact-form-container">
            <h3>Send a Message</h3>
            <form class="contact-form" @onsubmit="HandleSubmit">
                <div class="form-group">
                    <label for="name">Name</label>
                    <input type="text" id="name" placeholder="John Doe" required />
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" placeholder="john@example.com" required />
                </div>
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" rows="5" placeholder="Let's talk about machine learning..." required></textarea>
                </div>
                <button type="submit" class="btn-primary">Send Message</button>
            </form>
            
            @if (isSubmitted)
            {
                <p class="success-message">Thanks! This form is a UI mockup. Direct email works best for now.</p>
            }
        </div>
    </div>
</div>

@code {
    private bool isSubmitted = false;

    private void HandleSubmit()
    {
        // For now, this just shows a success message on the frontend.
        // Later, you can attach an API call here.
        isSubmitted = true;
    }
}